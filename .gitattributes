# ===========================================
# Git 属性配置
# 用于规范跨平台行尾和文件识别
# ===========================================

# 强制所有文本文件使用 LF 换行 (避免 Windows CRLF 污染)
* text=auto eol=lf

# Go 源码必须 LF
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# 文档使用 LF
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.html text eol=lf

# Shell 脚本
*.sh text eol=lf

# Dockerfile
Dockerfile text eol=lf
.dockerignore text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.tar binary
*.gz binary
*.zip binary

# 排除 linguist 统计 (降低误识别)
vendor/ linguist-vendored
bin/ linguist-generated
build/ linguist-generated
dist/ linguist-generated
*.min.js linguist-generated
*.min.css linguist-generated
