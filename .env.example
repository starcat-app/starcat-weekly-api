# ================================
# starcat-weekly-api .env.example
# ================================

# ──────────────── 服务端口 ────────────────
PORT=5003

# ──────────────── 存储 ────────────────
STORE_FILE=./weekly.db
# 生产环境：/data/weekly.db

REPO_DIR=./.weekly-repo
# 生产环境：/data/weekly-repo

# ──────────────── API 鉴权白名单 (必填) ────────────────
# 逗号分隔多个 key；用 supports/scripts/gen-api-key.sh 生成
API_KEYS=sk-starcat-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 来源同步、批量录入、批次查询和置顶管理专用管理员 Key。
# 不能与 API_KEYS 相同，因为 API_KEYS 会随客户端分发；未配置时所有 /internal 写入口不可用。
ADMIN_API_KEYS=sk-starcat-admin-XXXXXXXXXXXXXXXXXXXXXXXXXX

# ──────────────── GitHub PAT 池 (必填) ────────────────
# 逗号分隔多个 PAT；建议 2-3 个做冗余
# 注意：R-01 起从 GITHUB_TOKEN (单值) 改为 GITHUB_TOKENS (多值)
GITHUB_TOKENS=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ──────────────── Wiki 缓存预热（可选）────────────────
# 解析出新 repo 后自动通知 wiki-api 预热探测缓存。
# 不设置 WIKI_API_KEY 则禁用此功能（静默跳过）。
# WIKI_API_URL=http://127.0.0.1:5004
# WIKI_API_KEY=sk-starcat-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ──────────────── zread 周 trending cron（v0.5 R-02 新增）────────────────
# zread 端点周一 00:00 UTC 更新，默认每天 06:00 UTC 轮询（兼顾及时性与漏拉自愈）
ZREAD_TRENDING_CRON="0 6 * * *"

# ──────────────── AI Discovery（Show HN）v1.2 ────────────────
# HN 官方 API 抓取 → GitHub metadata/README enrichment 两阶段流水线。
# v1.2 已移除 LLM 分类阶段，不再需要 LLM_API_KEY / LLM_MODEL 等环境变量。
DISCOVERY_CRON="17 * * * *"
DISCOVERY_HN_LIMIT=30
DISCOVERY_BATCH_SIZE=20
DISCOVERY_RETRY_DELAY_MINUTES=60

# ──────────────── HelloGitHub 来源 ────────────────
# featured 日常增量与月刊对账错峰执行；历史回填只通过 admin API 显式启动。
HELLOGITHUB_CRON="31 6 * * *"
HELLOGITHUB_RECONCILE_CRON="29 7 29 * *"
HELLOGITHUB_FEATURED_MAX_PAGES=3
